# Leagueback web app environment template.
# Copy this file to .env.local and replace each placeholder before running locally.
# Set `SUPABASE_URL` and `NEXT_PUBLIC_SUPABASE_URL` to the same public Supabase URL.

# Supabase project URL (public app + client)
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key — safe for client-side use with RLS enforced
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret header value for the /api/backfill endpoint
BACKFILL_SECRET=your-backfill-secret

# Cloudflare Worker URL for Riot API proxy (optional, has a default)
# RIOT_PROXY_URL=https://riot-proxy.riot-proxy.workers.dev
