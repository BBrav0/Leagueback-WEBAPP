# Leagueback web app environment template.
# Copy this file to .env.local and replace each placeholder before running locally.

# Neon PostgreSQL connection string — used by lib/neon.ts for database access
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Secret header value for the /api/backfill endpoint
BACKFILL_SECRET=your-backfill-secret

# Riot API key — used by server-side API routes to call the Riot API directly
RIOT_API_KEY=your-riot-api-key

# HMAC key for analytics identifier hashing — server-only, min 32 chars
ANALYTICS_HMAC_KEY=your-analytics-hmac-key-at-least-32-characters
