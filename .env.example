# Leagueback web app environment template.
# Copy this file to .env.local and replace each placeholder before running locally.

# Neon PostgreSQL connection string — used by lib/neon.ts for database access
DATABASE_URL=<NEON_DATABASE_URL>

# Secret header value for the /api/backfill endpoint
# Set BACKFILL_SECRET to a random secret string
BACKFILL_SECRET=

# Riot API key — used by server-side API routes to call the Riot API directly
# Set RIOT_API_KEY to your Riot Games API key value
RIOT_API_KEY=

# Analytics API key — required for GET /api/analytics/summary (Hermes pull). Server-only.
# Set ANALYTICS_API_KEY to a random secret string for analytics summary auth
ANALYTICS_API_KEY=

# HMAC key for analytics identifier hashing — server-only, min 32 chars
# Set ANALYTICS_HMAC_KEY to a random string of at least 32 characters
ANALYTICS_HMAC_KEY=
