# Supabase project URL (also set as NEXT_PUBLIC_ for client-side use)
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key — safe for client-side (RLS enforced)
SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY, bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret header value for the /api/backfill endpoint
BACKFILL_SECRET=your-backfill-secret

# Cloudflare Worker URL for Riot API proxy (optional, has a default)
# RIOT_PROXY_URL=https://riot-proxy.riot-proxy.workers.dev
